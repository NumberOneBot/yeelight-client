{
  "name": "yeelight-cli",
  "version": "1.2.0",
  "description": "CLI tool for controlling Yeelight smart lights over LAN",
  "license": "MIT",
  "type": "module",
  "author": "NumberOneBot",
  "repository": {
    "type": "git",
    "url": "https://github.com/NumberOneBot/yeelight-client.git",
    "directory": "packages/cli"
  },
  "homepage": "https://numberonebot.github.io/yeelight-client",
  "bugs": "https://github.com/NumberOneBot/yeelight-client/issues",
  "keywords": [
    "yeelight",
    "smart-home",
    "cli",
    "iot",
    "led",
    "smart-light",
    "lan"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ylc": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build:node": "tsup",
    "prebuild:win": "magick -background none assets/icon-dark.svg -define icon:auto-resize=256,48,32,16 assets/icon-dark.ico",
    "build:win": "bun build src/index.tsx --compile --target bun-windows-x64 --outfile dist/ylc.exe",
    "postbuild:win": "node scripts/set-icon.mjs",
    "build:mac-arm64": "bun build src/index.tsx --compile --target bun-darwin-arm64 --outfile dist/ylc",
    "build:mac-x64": "bun build src/index.tsx --compile --target bun-darwin-x64 --outfile dist/ylc-x64",
    "build": "pnpm run build:node"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/react": "^18.0.0",
    "rcedit": "^5.0.2",
    "react-devtools-core": "^4.19.1"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "minimist": "^1.2.8",
    "react": "^18.0.0",
    "yeelight-client": "workspace:*"
  }
}
