{
  "name": "yeelight-client",
  "version": "1.0.1",
  "description": "TypeScript library for controlling Yeelight smart lights over LAN",
  "license": "MIT",
  "type": "module",
  "author": "NumberOneBot",
  "repository": {
    "type": "git",
    "url": "https://github.com/NumberOneBot/yeelight-client.git"
  },
  "homepage": "https://numberonebot.github.io/yeelight-client",
  "bugs": "https://github.com/NumberOneBot/yeelight-client/issues",
  "keywords": [
    "yeelight",
    "smart-home",
    "iot",
    "lan",
    "ssdp",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "docs:dev": "pnpm --filter yeelight-client-docs dev",
    "docs:build": "pnpm --filter yeelight-client-docs build",
    "release": "pnpm build ; pnpm changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.13.10",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
